<%- include('partials/topbar') %>
<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

  <%- include('partials/topbar') %>
  <%- include('partials/navbar') %>

  <div class="container-fluid flex-grow-1 py-3">
    <div class="row g-3">

      <!-- Sol Panel -->
      <div class="col-lg-2 col-md-3">
        <%- include('partials/sol-panel') %>
      </div>

      <!-- Ana İçerik -->
      <div class="col-lg-8 col-md-6">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">
              <i class="bi bi-house me-2"></i>Ana Sayfa
            </h5>
            <hr>
            <p>Hoş geldin, <strong><%= kullanici.ad %> <%= kullanici.soyad %></strong>!</p>
            <div class="row g-3 mt-1">
              <div class="col-md-4">
                <div class="card border-primary">
                  <div class="card-body text-center">
                    <i class="bi bi-box-seam fs-2 text-primary"></i>
                    <p class="mt-2 mb-0 small">Envanter</p>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card border-success">
                  <div class="card-body text-center">
                    <i class="bi bi-person-badge fs-2 text-success"></i>
                    <p class="mt-2 mb-0 small">Personel</p>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card border-warning">
                  <div class="card-body text-center">
                    <i class="bi bi-map fs-2 text-warning"></i>
                    <p class="mt-2 mb-0 small">Operasyon</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sağ Panel -->
      <div class="col-lg-2 col-md-3">
        <%- include('partials/sag-panel') %>
      </div>

    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>