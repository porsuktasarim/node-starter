<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('../partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

  <%- include('../partials/topbar') %>
  <%- include('../partials/navbar') %>

  <div class="container-fluid flex-grow-1 py-3">
    <div class="row g-3">

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sol-panel') %>
      </div>

      <div class="col-lg-8 col-md-6">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/yonetim/gruplar">Gruplar</a></li>
            <li class="breadcrumb-item active"><%= grup.ad %></li>
          </ol>
        </nav>

        <!-- Grup Bilgileri -->
        <div class="card shadow-sm mb-3">
          <div class="card-header fw-bold">
            <i class="bi bi-shield-lock me-2"></i><%= grup.ad %>
            <code class="ms-2 small">(<%= grup.kod %>)</code>
          </div>
          <div class="card-body small">
            <strong>İzin Sayısı:</strong> <%= grup.izinler.length %><br>
            <strong>Kullanıcı Sayısı:</strong> <%= kullanicilar.length %>
          </div>
        </div>

        <!-- İzinler -->
        <div class="card shadow-sm mb-3">
          <div class="card-header fw-bold">
            <i class="bi bi-key me-2"></i>Modül İzinleri
          </div>
          <div class="card-body">
            <% if (grup.izinler.length === 0) { %>
              <p class="text-muted mb-0">Henüz izin atanmamış.</p>
            <% } else { %>
              <% MODULLER.forEach(modul => { %>
                <% const modulIzinleri = modul.izinler.filter(i => grup.izinler.includes(i.kod)); %>
                <% if (modulIzinleri.length > 0) { %>
                  <div class="mb-2">
                    <span class="badge bg-secondary me-1"><%= modul.ad %></span>
                    <% modulIzinleri.forEach(izin => { %>
                      <span class="badge bg-light text-dark border me-1 small"><%= izin.ad %></span>
                    <% }) %>
                  </div>
                <% } %>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Kullanıcılar -->
        <div class="card shadow-sm">
          <div class="card-header fw-bold">
            <i class="bi bi-people me-2"></i>Bu Gruptaki Kullanıcılar
          </div>
          <div class="card-body p-0">
            <% if (kullanicilar.length === 0) { %>
              <p class="text-muted text-center py-3 mb-0">Bu grupta kullanıcı yok.</p>
            <% } else { %>
              <table class="table table-hover mb-0">
                <thead class="table-dark">
                  <tr>
                    <th>Ad Soyad</th>
                    <th>Kullanıcı Adı</th>
                    <th>Ünvan</th>
                    <th>Organizasyon</th>
                    <th>Durum</th>
                  </tr>
                </thead>
                <tbody>
                  <% kullanicilar.forEach(k => { %>
                  <tr>
                    <td><%= k.ad %> <%= k.soyad %></td>
                    <td><%= k.kullaniciAdi %></td>
                    <td><%= k.unvan || '—' %></td>
                    <td><%= k.organizasyon ? k.organizasyon.ad : '—' %></td>
                    <td>
                      <span class="badge <%= k.aktif ? 'bg-success' : 'bg-warning text-dark' %>">
                        <%= k.aktif ? 'Aktif' : 'Pasif' %>
                      </span>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>

      </div>

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sag-panel') %>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>