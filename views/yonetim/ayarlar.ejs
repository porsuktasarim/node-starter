<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('../partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

  <%- include('../partials/topbar') %>
  <%- include('../partials/navbar') %>

  <div class="container-fluid flex-grow-1 py-3">
    <div class="row g-3">

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sol-panel') %>
      </div>

      <div class="col-lg-8 col-md-6">

        <% if (basari) { %>
          <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i><%= basari %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (hata) { %>
          <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i><%= hata %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="card shadow-sm">
          <div class="card-header fw-bold">
            <i class="bi bi-sliders me-2"></i>Sistem Ayarları
          </div>
          <div class="card-body">
            <form method="POST" action="/yonetim/ayarlar" enctype="multipart/form-data">
              <div class="row g-3">

                <div class="col-md-6">
                  <label class="form-label">Sistem Adı</label>
                  <input type="text" name="sistemAdi" class="form-control" value="<%= ayarlar.sistemAdi %>">
                </div>

                <div class="col-md-6">
                  <label class="form-label">Kurum Adı</label>
                  <input type="text" name="kurumAdi" class="form-control" value="<%= ayarlar.kurumAdi %>">
                </div>

                <div class="col-md-12">
                  <label class="form-label">Kurum Logosu</label>
                  <% if (ayarlar.logo) { %>
                    <div class="mb-2">
                      <img src="<%= ayarlar.logo %>" height="50" alt="Logo" class="border p-1">
                    </div>
                  <% } %>
                  <input type="file" name="logo" class="form-control" accept="image/*">
                  <div class="form-text">PNG veya JPG, max 2MB. Mevcut logoyu değiştirmek için yeni dosya seçin.</div>
                </div>

              </div>

              <hr class="my-4">
              <h6 class="fw-bold mb-3"><i class="bi bi-person-badge me-2"></i>Kimlik Kartı Ayarları</h6>
              <div class="row g-3">
                <div class="col-md-12">
                  <div class="alert alert-info small">
                    <i class="bi bi-info-circle me-2"></i>
                    Kimlik kartı boyutu: 5.5 x 8.5 cm (CR80 standart kart). Arkalı önlü basım desteklenir.
                  </div>
                </div>
              </div>

              <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-save me-1"></i>Kaydet
                </button>
              </div>
            </form>
          </div>
        </div>

      </div>

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sag-panel') %>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>