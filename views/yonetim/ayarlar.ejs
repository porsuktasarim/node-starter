<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('../partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

  <%- include('../partials/topbar') %>
  <%- include('../partials/navbar') %>

  <div class="container-fluid flex-grow-1 py-3">
    <div class="row g-3">

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sol-panel') %>
      </div>

      <div class="col-lg-8 col-md-6">

        <% if (basari) { %>
          <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i><%= basari %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (hata) { %>
          <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i><%= hata %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="card shadow-sm">
          <div class="card-header fw-bold">
            <i class="bi bi-sliders me-2"></i>Sistem Ayarları
          </div>
          <div class="card-body">
            <form method="POST" action="/yonetim/ayarlar" enctype="multipart/form-data">
              <div class="row g-3">

                <div class="col-md-6">
                  <label class="form-label">Sistem Adı</label>
                  <input type="text" name="sistemAdi" class="form-control" value="<%= ayarlar.sistemAdi %>">
                </div>

                <div class="col-md-6">
                  <label class="form-label">Kurum Adı</label>
                  <input type="text" name="kurumAdi" class="form-control" value="<%= ayarlar.kurumAdi %>">
                </div>

                <div class="col-md-12">
                  <label class="form-label">Kurum Logosu</label>
                  <% if (ayarlar.logo) { %>
                    <div class="mb-2">
                      <img src="<%= ayarlar.logo %>" height="50" alt="Logo" class="border p-1">
                    </div>
                  <% } %>
                  <input type="file" name="logo" class="form-control" accept="image/*">
                  <div class="form-text">PNG veya JPG, max 2MB. Mevcut logoyu değiştirmek için yeni dosya seçin.</div>
                </div>

              </div>

              <hr class="my-4">
              <h6 class="fw-bold mb-3"><i class="bi bi-person-badge me-2"></i>Kimlik Kartı Ayarları</h6>
              <div class="row g-3">
                <div class="col-md-12">
                  <div class="alert alert-info small">
                    <i class="bi bi-info-circle me-2"></i>
                    Kimlik kartı boyutu: 5.5 x 8.5 cm (CR80 standart kart). Arkalı önlü basım desteklenir.
                  </div>
                </div>
              </div>

              <hr class="my-4">
              <h6 class="fw-bold mb-3"><i class="bi bi-fonts me-2"></i>Font Ayarları</h6>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Normal Font</label>
                  <select name="fontAdi" class="form-select">
                    <option value="MYRIADPRO-REGULAR.OTF" <%= ayarlar.fontAdi === 'MYRIADPRO-REGULAR.OTF' ? 'selected' : '' %>>Myriad Pro Regular</option>
                    <option value="MYRIADPRO-COND.OTF" <%= ayarlar.fontAdi === 'MYRIADPRO-COND.OTF' ? 'selected' : '' %>>Myriad Pro Condensed</option>
                    <option value="MYRIADPRO-CONDIT.OTF" <%= ayarlar.fontAdi === 'MYRIADPRO-CONDIT.OTF' ? 'selected' : '' %>>Myriad Pro Condensed Italic</option>
                    <option value="MyriadPro-Light.otf" <%= ayarlar.fontAdi === 'MyriadPro-Light.otf' ? 'selected' : '' %>>Myriad Pro Light</option>
                    <option value="MYRIADPRO-SEMIBOLDIT.OTF" <%= ayarlar.fontAdi === 'MYRIADPRO-SEMIBOLDIT.OTF' ? 'selected' : '' %>>Myriad Pro Semibold Italic</option>
                    <option value="MinionPro-Regular.otf" <%= ayarlar.fontAdi === 'MinionPro-Regular.otf' ? 'selected' : '' %>>Minion Pro Regular</option>
                    <option value="MinionPro-Medium.otf" <%= ayarlar.fontAdi === 'MinionPro-Medium.otf' ? 'selected' : '' %>>Minion Pro Medium</option>
                    <option value="MinionPro-MediumIt.otf" <%= ayarlar.fontAdi === 'MinionPro-MediumIt.otf' ? 'selected' : '' %>>Minion Pro Medium Italic</option>
                    <option value="MinionPro-It.otf" <%= ayarlar.fontAdi === 'MinionPro-It.otf' ? 'selected' : '' %>>Minion Pro Italic</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Kalın Font</label>
                  <select name="fontKalin" class="form-select">
                    <option value="MYRIADPRO-BOLD.OTF" <%= ayarlar.fontKalin === 'MYRIADPRO-BOLD.OTF' ? 'selected' : '' %>>Myriad Pro Bold</option>
                    <option value="MYRIADPRO-BOLDCOND.OTF" <%= ayarlar.fontKalin === 'MYRIADPRO-BOLDCOND.OTF' ? 'selected' : '' %>>Myriad Pro Bold Condensed</option>
                    <option value="MYRIADPRO-BOLDCONDIT.OTF" <%= ayarlar.fontKalin === 'MYRIADPRO-BOLDCONDIT.OTF' ? 'selected' : '' %>>Myriad Pro Bold Condensed Italic</option>
                    <option value="MYRIADPRO-BOLDIT.OTF" <%= ayarlar.fontKalin === 'MYRIADPRO-BOLDIT.OTF' ? 'selected' : '' %>>Myriad Pro Bold Italic</option>
                    <option value="MYRIADPRO-SEMIBOLD.OTF" <%= ayarlar.fontKalin === 'MYRIADPRO-SEMIBOLD.OTF' ? 'selected' : '' %>>Myriad Pro Semibold</option>
                    <option value="MYRIADPRO-SEMIBOLDIT.OTF" <%= ayarlar.fontKalin === 'MYRIADPRO-SEMIBOLDIT.OTF' ? 'selected' : '' %>>Myriad Pro Semibold Italic</option>
                    <option value="MinionPro-Bold.otf" <%= ayarlar.fontKalin === 'MinionPro-Bold.otf' ? 'selected' : '' %>>Minion Pro Bold</option>
                    <option value="MinionPro-BoldIt.otf" <%= ayarlar.fontKalin === 'MinionPro-BoldIt.otf' ? 'selected' : '' %>>Minion Pro Bold Italic</option>
                    <option value="MinionPro-BoldCn.otf" <%= ayarlar.fontKalin === 'MinionPro-BoldCn.otf' ? 'selected' : '' %>>Minion Pro Bold Condensed</option>
                    <option value="MinionPro-BoldCnIt.otf" <%= ayarlar.fontKalin === 'MinionPro-BoldCnIt.otf' ? 'selected' : '' %>>Minion Pro Bold Condensed Italic</option>
                    <option value="MinionPro-Semibold.otf" <%= ayarlar.fontKalin === 'MinionPro-Semibold.otf' ? 'selected' : '' %>>Minion Pro Semibold</option>
                    <option value="MinionPro-SemiboldIt.otf" <%= ayarlar.fontKalin === 'MinionPro-SemiboldIt.otf' ? 'selected' : '' %>>Minion Pro Semibold Italic</option>
                  </select>
                </div>
              </div>

              <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-save me-1"></i>Kaydet
                </button>
              </div>
            </form>
          </div>
        </div>

      </div>

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sag-panel') %>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>