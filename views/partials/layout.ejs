<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('head') %>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

  <%- include('topbar') %>
  <%- include('navbar') %>

  <div class="container-fluid flex-grow-1 py-3">
    <div class="row g-3">

      <!-- Sol Panel -->
      <div class="col-lg-2 col-md-3">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-secondary text-white small fw-bold">
            <i class="bi bi-lightning me-1"></i>Hızlı Erişim
          </div>
          <div class="list-group list-group-flush">
            <a href="/yonetim/kullanicilar" class="list-group-item list-group-item-action small">
              <i class="bi bi-people me-2"></i>Kullanıcılar
            </a>
            <a href="/envanter/ekipmanlar" class="list-group-item list-group-item-action small">
              <i class="bi bi-tools me-2"></i>Ekipmanlar
            </a>
            <a href="/personel/kartlar" class="list-group-item list-group-item-action small">
              <i class="bi bi-person-lines-fill me-2"></i>Personel
            </a>
            <a href="/sayim/gorevler" class="list-group-item list-group-item-action small">
              <i class="bi bi-list-check me-2"></i>Sayım
            </a>
            <a href="/operasyon/liste" class="list-group-item list-group-item-action small">
              <i class="bi bi-flag me-2"></i>Operasyon
            </a>
            <a href="/raporlar/dashboard" class="list-group-item list-group-item-action small">
              <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
          </div>
        </div>
      </div>

      <!-- Ana İçerik -->
      <div class="col-lg-8 col-md-6">
        <%- body %>
      </div>

      <!-- Sağ Panel -->
      <div class="col-lg-2 col-md-3">
        <div class="card shadow-sm mb-3">
          <div class="card-header bg-secondary text-white small fw-bold">
            <i class="bi bi-bell me-1"></i>Bildirimler
          </div>
          <div class="card-body small text-muted">
            Henüz bildirim yok.
          </div>
        </div>
        <div class="card shadow-sm">
          <div class="card-header bg-secondary text-white small fw-bold">
            <i class="bi bi-info-circle me-1"></i>Özet
          </div>
          <div class="card-body small">
            <div class="d-flex justify-content-between">
              <span>Kullanıcılar</span>
              <span class="badge bg-primary">—</span>
            </div>
            <div class="d-flex justify-content-between mt-1">
              <span>Ekipmanlar</span>
              <span class="badge bg-success">—</span>
            </div>
            <div class="d-flex justify-content-between mt-1">
              <span>Operasyonlar</span>
              <span class="badge bg-warning text-dark">—</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <%- include('footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>