<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('../partials/head') %>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

  <%- include('../partials/topbar') %>
  <%- include('../partials/navbar') %>

  <div class="container-fluid flex-grow-1 py-3">
    <div class="row g-3">

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sol-panel') %>
      </div>

      <div class="col-lg-8 col-md-6">

        <% if (basari) { %>
          <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i><%= basari %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (hata) { %>
          <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i><%= hata %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="card shadow-sm">
          <div class="card-header fw-bold">
            <i class="bi bi-person-circle me-2"></i>Profilim
          </div>
          <div class="card-body">
            <form method="POST" action="/profil" enctype="multipart/form-data">
              <div class="row g-3">
                <div class="col-md-12 text-center mb-3">
                  <% if (kullanici.fotograf) { %>
                    <img src="<%= kullanici.fotograf %>" class="rounded-circle mb-2" width="100" height="100" style="object-fit:cover">
                  <% } else { %>
                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-2" style="width:100px;height:100px">
                      <i class="bi bi-person-fill text-white fs-1"></i>
                    </div>
                  <% } %>
                  <div>
                    <label class="form-label">Fotoğraf</label>
                    <input type="file" name="fotograf" class="form-control" accept="image/*">
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Ad</label>
                  <input type="text" name="ad" class="form-control" value="<%= kullanici.ad %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Soyad</label>
                  <input type="text" name="soyad" class="form-control" value="<%= kullanici.soyad %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">E-posta</label>
                  <input type="email" name="email" class="form-control" value="<%= kullanici.email %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Kullanici Adi</label>
                  <input type="text" class="form-control" value="<%= kullanici.kullaniciAdi %>" disabled>
                </div>
                <hr>
                <p class="fw-bold mb-0">Sifre Degistir <small class="text-muted fw-normal">(degistirmeyecekseniz bos birakin)</small></p>
                <div class="col-md-6">
                  <label class="form-label">Mevcut Sifre</label>
                  <input type="password" name="mevcutSifre" class="form-control">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Yeni Sifre</label>
                  <input type="password" name="yeniSifre" class="form-control">
                </div>
              </div>
              <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-save me-1"></i>Kaydet
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-2 col-md-3">
        <%- include('../partials/sag-panel') %>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>tamam